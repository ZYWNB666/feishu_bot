APP_ID=cli_a9***************
APP_SECRET=xxxxxxxxxxxxxxxxxxxx
LARK_HOST=https://open.feishu.cn
VERIFICATION_TOKEN=
ENCRYPT_KEY=


# ==================== MySQL配置====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=config_db
MYSQL_CHARSET=utf8mb4


# ==================== 服务器配置 ====================
# http监听地址和端口
PORT=3000
HOST=0.0.0.0


# Flask调试模式
DEBUG=false


# ==================== 日志配置 ====================
# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== Flashcat oncall 配置 ====================
FLASHCAT_APP_KEY=
FLASHCAT_SCHEDULE_ID=
FEISHU_USER_ACCESS_TOKEN=
# 电话告警 integration_key（旧接口，severity=phone 时触发）
FLASHCAT_PHONE_INTEGRATION_KEY=
# Flashcat incident channel_id（创建电话告警 incident 时使用）
FLASHCAT_CHANNEL_ID=


# ==================== 性能优化配置（可选，均有默认值） ====================
# ── 数据库连接池 ──
# 连接池大小
MYSQL_POOL_SIZE=10
# 连接池获取连接超时（秒）
MYSQL_POOL_ACQUIRE_TIMEOUT=30

# ── 告警去重缓存 ──
# firing 批次去重 TTL（秒）
ALERT_DEDUP_TTL=300
# resolved 批次去重 TTL（秒）
RESOLVED_DEDUP_TTL=1800
# 各类去重缓存最大条目数（防内存无限增长）
ALERT_DEDUP_CACHE_MAXSIZE=50000

# ── 飞书事件/回调去重 ──
EVENT_CACHE_TTL=3600
EVENT_CACHE_MAXSIZE=20000
CALLBACK_CACHE_TTL=5
CALLBACK_CACHE_MAXSIZE=10000

# ── HTTP 超时（秒）──
FEISHU_API_TIMEOUT=10
FLASHCAT_API_TIMEOUT=10
SILENCE_API_TIMEOUT=30

# ── 重试策略 ──
MAX_RETRIES=3
RETRY_BACKOFF_BASE=2

# ── token 缓存安全余量（秒）──
TOKEN_REFRESH_BUFFER=300

# ── 路由配置静态缓存 ──
# alert_config（含 label_rules）内存缓存 TTL（秒）
ALERT_CONFIG_CACHE_TTL=30

# ── 告警统计默认值 ──
ALERT_STATS_DEFAULT_DAYS=7
ALERT_STATS_DEFAULT_TOP_LIMIT=20
ALERT_STATS_DEFAULT_DETAILS_LIMIT=200

# ── 告警记录 ──
# MAID 随机字符串长度
MAID_LENGTH=20
